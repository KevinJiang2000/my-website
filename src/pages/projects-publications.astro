---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<BaseLayout title="projects-publications | Weihang Jiang">
  <main class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="text-4xl font-semibold tracking-tight">Projects</h1>
    <p class="mt-4 max-w-5xl text-neutral-400 leading-7">
      Selected research and technical projects across neuroscience, machine learning,
      and software-related work.
    </p>

    <div class="mt-5 grid gap-6 text-lg">
      <ProjectCard
        title="EEG Decoding of Color Representation"
        year="2023–2026"
        description="Master thesis of early neural representations of hue using EEG decoding, confusion-matrix analysis, and computational modeling."
        tags={["EEG", "Machine learning", "Mathematical Statistics", "Signal Processing"]}
      />

      <ProjectCard
        title="Spike Sorting with Spiking Neural Networks"
        year="2022-2023"
        description="Undergraduate thesis research exploring spike classification stability and optimal conditions for spike sorting with SNN-based approaches."
        tags={["SNN", "Signal Processing", "Machine learning"]}
      />
    </div>

    <h1 class="text-4xl font-semibold mt-10">Publications</h1>
    <div class="mt-5 grid gap-6 text-lg">
      <ProjectCard
        title="Early EEG hue representations for single-color stimuli are consistent with low-level mechanism-like coding (Under Reviewing)"
        year="2026"
        description="Weihang Jiang, Takahiro Nagai"
        tags={["EEG", "Machine learning", "Mathematical Statistics", "Signal Processing"]}
      />

      <ProjectCard
        title="脳波デコーディングに基づく視覚野の色選択性の解析 (Academic Presentation)"
        year="2025"
        description="Weihang Jiang, Takehiro Nagai, 栗木一郎, 日本視覚学会2025年冬季大会, VISION, Vol. 37, No. 1, p. 30, Jan. 2025.
        https://doi.org/10.24636/vision.37.1_9"
        tags={["EEG", "Machine learning", "Mathematical Statistics", "Signal Processing"]}
      />
    </div>
  </main>
</BaseLayout>