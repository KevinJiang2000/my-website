---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<BaseLayout title="Blog | Weihang Jiang">
  <main class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="text-5xl font-semibold tracking-tight">Blog</h1>

    <p class="mt-4 text-neutral-400">
      Total posts: {posts.length}
    </p>

    <div class="mt-10 space-y-6 text-xl">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="group block relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition duration-300 hover:-translate-y-0.5 hover:border-neutral-700 hover:bg-white/[0.05] hover:shadow-[0_16px_40px_rgba(0,0,0,0.3)]"
        >
          <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100">
            <div class="absolute left-0 top-0 h-24 w-24 rounded-full bg-sky-400/8 blur-2xl"></div>
          </div>

          <div class="relative z-10">
            <h2 class="text-2xl font-semibold tracking-tight text-neutral-100 transition group-hover:text-white">
              {post.data.title}
            </h2>

            <p class="mt-3 text-neutral-400 leading-7">
              {post.data.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>