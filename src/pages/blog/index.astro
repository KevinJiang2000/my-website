---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<BaseLayout title="Blog | Weihang Jiang">
  <main class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="text-4xl font-semibold tracking-tight">Blog</h1>

    <p class="mt-4 text-neutral-400">
      Total posts: {posts.length}
    </p>

    <div class="mt-10 space-y-6">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="block rounded-2xl border border-neutral-800 p-6 transition hover:border-neutral-700 hover:bg-neutral-900/40"
        >
          <h2 class="text-2xl font-medium text-neutral-100">{post.data.title}</h2>
          <p class="mt-3 text-neutral-400">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>