---
interface Props {
  title: string;
  description: string;
  year?: string;
  tags?: string[];
}

const { title, description, year, tags = [] } = Astro.props;
---

<article
  class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.02)] transition duration-300 hover:-translate-y-1 hover:border-sky-300/20 hover:bg-white/[0.05] hover:shadow-[0_20px_60px_rgba(0,0,0,0.35)]"
>
  <!-- subtle glow -->
  <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100">
    <div class="absolute -left-10 top-0 h-32 w-32 rounded-full bg-sky-400/10 blur-2xl"></div>
    <div class="absolute bottom-0 right-0 h-28 w-28 rounded-full bg-indigo-400/10 blur-2xl"></div>
  </div>

  <!-- content -->
  <div class="relative z-10">
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-xl font-semibold tracking-tight text-neutral-100 transition duration-300 group-hover:text-white">
        {title}
      </h3>

      {year && (
        <span class="shrink-0 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs font-medium text-neutral-400">
          {year}
        </span>
      )}
    </div>

    <p class="mt-4 leading-7 text-neutral-400">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span
            class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-medium text-neutral-300 transition duration-300 group-hover:border-white/15 group-hover:bg-white/[0.06]"
          >
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>